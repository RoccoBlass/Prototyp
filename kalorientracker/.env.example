# Vorlage für die lokalen Umgebungsvariablen.
# Kopiere diese Datei zu ".env" und trage deine eigenen Werte ein.
# Die echte .env wird NICHT eingecheckt (siehe .gitignore).

# MongoDB-Verbindung (erforderlich) – z. B. ein MongoDB-Atlas-Connection-String:
DB_URI="mongodb+srv://BENUTZER:PASSWORT@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# OpenRouter (optional) – nur für die KI-Funktionen nötig
# (KI-Coach 4.7, Foto-Schätzung 4.8, Freitext-Schätzung 4.9).
# Key erstellen unter https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Modell mit Vision-Fähigkeit (für die Foto-Schätzung):
OPENROUTER_MODEL="google/gemini-2.0-flash-001"
